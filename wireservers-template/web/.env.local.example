# Copy to .env.local. Never commit real secrets.

AUTH_SECRET=replace-with-32-byte-random
AUTH_URL=http://localhost:3002

# Entra External ID tenant used by ws-security.
AUTH_MICROSOFT_ENTRA_ID_ID=00000000-0000-0000-0000-000000000000
AUTH_MICROSOFT_ENTRA_ID_SECRET=client-secret-from-portal
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://36c719fe-966c-4780-bce5-3a856b21a634.ciamlogin.com/36c719fe-966c-4780-bce5-3a856b21a634/v2.0

# Register this redirect URI on the web app registration:
#   http://localhost:3002/api/msal/callback
NEXT_PUBLIC_API_SCOPE=api://8be27615-1971-4313-ac42-b0144372844c/access_as_user
NEXT_PUBLIC_API_BASE_URL=https://ws-security.azurewebsites.net
NEXT_PUBLIC_PURPOSE_OF_USE=operations
